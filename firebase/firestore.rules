rules_version = '2';

// Firestore security rules for Kothar.
// Only paths used by the app are allowed; all others are explicitly denied.
// See docs/18-FIREBASE-FIRESTORE-STORAGE.md for data model and deployment.
service cloud.firestore {
  match /databases/{database}/documents {

    // Template request orders: owner-only.
    // Creation requires a valid daily-limit counter in the same transaction.
    // When counter does not exist, allow (first request); otherwise getAfter validates post-transaction count.
    match /users/{userId}/orders/{orderId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId
        && (
          !exists(/databases/$(database)/documents/users/$(userId)/requestLimits/daily)
          || getAfter(/databases/$(database)/documents/users/$(userId)/requestLimits/daily).data.count <= 3
        );
    }

    // Daily request creation limit counter.
    // Written atomically with order creation in a transaction.
    // Count can only be 1 (new day or first request) or incremented by 1 (same day).
    match /users/{userId}/requestLimits/{limitId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId
        && request.resource.data.count == 1
        && request.resource.data.date is string;
      allow update: if request.auth != null && request.auth.uid == userId
        && request.resource.data.count is int
        && request.resource.data.count <= 3
        && (
          (request.resource.data.date != resource.data.date && request.resource.data.count == 1)
          || (request.resource.data.date == resource.data.date && request.resource.data.count == resource.data.count + 1)
        );
    }

    // User-submitted issue reports: create-only; no client read/update/delete.
    match /users/{userId}/reports/{reportId} {
      allow read: if false;
      allow update: if false;
      allow delete: if false;
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly([
          'message',
          'category',
          'createdAt',
          'locale',
          'routePath',
          'userEmail',
          'userDisplayName'
        ])
        && request.resource.data.message is string
        && request.resource.data.message.size() >= 1
        && request.resource.data.message.size() <= 4000
        && request.resource.data.category in ['bug', 'ui', 'account', 'billing', 'other']
        && request.resource.data.createdAt == request.time
        && request.resource.data.locale is string
        && request.resource.data.locale.size() >= 1
        && request.resource.data.locale.size() <= 64
        && request.resource.data.routePath is string
        && request.resource.data.routePath.size() >= 1
        && request.resource.data.routePath.size() <= 512
        && request.resource.data.routePath.matches('^/.*')
        && (request.resource.data.userEmail == null || request.resource.data.userEmail is string)
        && (request.resource.data.userDisplayName == null || request.resource.data.userDisplayName is string)
        && (request.resource.data.userEmail == null || request.resource.data.userEmail.size() <= 320)
        && (request.resource.data.userDisplayName == null || request.resource.data.userDisplayName.size() <= 200);
    }

    // Explicit deny for all other paths (no other collections used by the app).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
