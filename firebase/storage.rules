rules_version = '2';

// Firebase Storage security rules for Kothar.
// Order attachments are stored at: orders/{userId}/{orderId}/{fileName}
// Only the authenticated owner can read/write their own order files.
// See docs/18-FIREBASE-FIRESTORE-STORAGE.md for paths and deployment.
service firebase.storage {
  match /b/{bucket}/o {
    match /orders/{userId}/{orderId}/{fileName} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
